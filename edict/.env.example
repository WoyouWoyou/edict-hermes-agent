# Edict Hermes Agent example env
# Copy this file to edict/.env for Docker Compose or local development.

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edict
POSTGRES_USER=edict
POSTGRES_PASSWORD=edict_secret_change_me
DATABASE_URL=postgresql+asyncpg://edict:edict_secret_change_me@localhost:5432/edict

# Redis
REDIS_URL=redis://localhost:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production
DEBUG=true

# Hermes Agent
HERMES_BIN=hermes
HERMES_HOME=.hermes
HERMES_PROJECT_DIR=.
HERMES_SOURCE=edict

# Optional. Leave empty to let Hermes profile/config decide.
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TOOLSETS=

# Optional model provider keys. Hermes may also read its own config.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Dispatcher
STALL_THRESHOLD_SEC=180
MAX_DISPATCH_RETRY=3
DISPATCH_TIMEOUT_SEC=300
HEARTBEAT_INTERVAL_SEC=30
DISPATCH_HERMES_TOOLSETS=search
DISPATCH_HERMES_MAX_TURNS=3

# Court discussion
COURT_HERMES_ENABLED=true
COURT_HERMES_CONCURRENCY=2
COURT_HERMES_TIMEOUT_SEC=120

# Notifications are optional. Empty means dashboard-only.
NOTIFICATION_ENABLED=false
DEFAULT_DISPATCH_CHANNEL=
